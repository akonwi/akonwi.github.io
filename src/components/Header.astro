---
import { site } from "../site";
---

<header class="site-header">
  <div class="top-bar">
    <h1 class="site-title">
      <a href="/">{site.title}</a>
    </h1>
    <nav class="nav">
      <ul>
        <li>
          <a class="page-link" href="/">
            <span class="octicon octicon-home"></span>
            <span class="text">Blog</span>
          </a>
        </li>
        <li>
          <a class="page-link" href="/about/">
            <span class="octicon octicon-heart"></span>
            <span class="text">About</span>
          </a>
        </li>
        <li>
          <a class="page-link" href="/projects/">
            <span class="octicon octicon-microscope"></span>
            <span class="text">Projects</span>
          </a>
        </li>
        <li>
          <a class="page-link" href={`https://github.com/${site.githubUsername}/`}>
            <span class="octicon octicon-octoface"></span>
            <span class="text">Github</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
