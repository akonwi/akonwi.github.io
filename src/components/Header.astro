---
import { site } from "../site";

const { currentPath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Blog" },
  { href: "/about/", label: "About" },
  { href: "/projects/", label: "Projects" },
  { href: `https://github.com/${site.githubUsername}/`, label: "GitHub", external: true }
];

const isActive = (href, external) => {
  if (external) {
    return false;
  }

  return href === "/" ? currentPath === "/" : currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="top-bar" data-animate="slide-in">
    <a class="site-title" href="/">
      <span class="wordmark">{site.title}</span>
      <span class="tagline">notes on software + life</span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      <ul>
        {links.map((link) => (
          <li>
            <a
              class:list={["page-link", { active: isActive(link.href, link.external) }]}
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
