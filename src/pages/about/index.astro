---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { marked } from "marked";

import aboutContent from "../../content/pages/about.md?raw";
const aboutHtml = marked.parse(aboutContent);
---

<BaseLayout title="About" canonicalPath="/about/">
  <section class="post page-content" data-animate="fade-in">
    <header class="post-header">
      <h2>About</h2>
    </header>

    <div class="post-content" set:html={aboutHtml}></div>
  </section>
</BaseLayout>
